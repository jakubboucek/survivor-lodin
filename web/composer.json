{
    "name": "jakubboucek/survival",
    "description": "Survival game web built with Nette Framework",
    "license": [
        "MIT",
        "BSD-3-Clause",
        "GPL-2.0-only",
        "GPL-3.0-only"
    ],
    "type": "project",
    "keywords": [
        "nette"
    ],
    "require": {
        "php": ">= 8.5",
        "ext-exif": "*",
        "ext-gd": "*",
        "latte/latte": "^3.1",
        "nette/application": "^3.2.3",
        "nette/assets": "^1.0.0",
        "nette/bootstrap": "^3.2.6",
        "nette/caching": "^3.2",
        "nette/database": "^3.2",
        "nette/di": "^3.2",
        "nette/forms": "^3.2",
        "nette/http": "^3.3",
        "nette/mail": "^4.0",
        "nette/robot-loader": "^4.0",
        "nette/security": "^3.2",
        "nette/utils": "^4.0",
        "tracy/tracy": "^2.10",
        "redbitcz/debug-mode-enabler": "^5.0"
    },
    "require-dev": {
        "nette/phpstan-rules": "^1.0.3",
        "nette/tester": "^2.5",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1"
    },
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "App\\": "app"
        }
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "phpstan": "phpstan analyse",
        "tester": "tester tests -s"
    }
}
