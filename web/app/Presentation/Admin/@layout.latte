<!DOCTYPE html>
<html lang="cs" data-theme="light">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{ifset title}{include title|stripHtml} — {/ifset}Administrace · Survival Lodín</title>
    {include '../@icons.latte'}
    {asset? 'admin.js'}
</head>

<body class="min-h-screen bg-base-200">
    <div class="navbar bg-base-100 shadow-sm">
        <div class="flex-1">
            <a href="{plink :Admin:Dashboard:}" class="btn btn-ghost text-lg">Survival Lodín · Admin</a>
        </div>
        <div class="flex-none" n:if="$user->isLoggedIn()">
            <ul class="menu menu-horizontal gap-1 px-1">
                <li>
                    <a href="{plink :Admin:Dashboard:}" n:class="$presenter->isLinkCurrent(':Admin:Dashboard:*') ? 'menu-active' : null">Přehled</a>
                </li>
                <li>
                    <a href="{plink :Admin:Games:}" n:class="$presenter->isLinkCurrent(':Admin:Games:*') ? 'menu-active' : null">Hry</a>
                </li>
                <li>
                    <a href="{plink :Admin:Teams:}" n:class="$presenter->isLinkCurrent(':Admin:Teams:*') ? 'menu-active' : null">Týmy</a>
                </li>
                <li>
                    <a href="{plink :Admin:Links:}" n:class="$presenter->isLinkCurrent(':Admin:Links:*') ? 'menu-active' : null">Odkazy</a>
                </li>
                <li>
                    <a href="{plink :Admin:Files:}" n:class="$presenter->isLinkCurrent(':Admin:Files:*') ? 'menu-active' : null">Soubory</a>
                </li>
                <li>
                    <a href="{plink :Admin:Morse:}" n:class="$presenter->isLinkCurrent(':Admin:Morse:*') ? 'menu-active' : null">Morse</a>
                </li>
                <li>
                    <a href="{plink :Admin:Ivr:}" n:class="$presenter->isLinkCurrent(':Admin:Ivr:*') ? 'menu-active' : null">IVR</a>
                </li>
                <li>
                    <a href="{plink :Admin:Users:}" n:class="$presenter->isLinkCurrent(':Admin:Users:*') ? 'menu-active' : null">Správci</a>
                </li>
                <li>
                    <a href="{plink :Admin:Options:}" n:class="$presenter->isLinkCurrent(':Admin:Options:*') ? 'menu-active' : null">Možnosti</a>
                </li>
                <li><a href="{plink :Home:}" target="_blank">Web ↗</a></li>
                <li>
                    <details>
                        <summary>{$user->getIdentity()->nick}</summary>
                        <ul class="right-0 z-1 w-44 rounded-t-none bg-base-100 p-2 shadow">
                            <li><a href="{plink :Sign:out}">Odhlásit</a></li>
                        </ul>
                    </details>
                </li>
            </ul>
        </div>
    </div>

    <main class="container mx-auto p-4 sm:p-6">
        {ifset #breadcrumbs}
        <div class="breadcrumbs mb-4 text-sm text-base-content/70">
            <ul>{include #breadcrumbs}</ul>
        </div>
        {/ifset}

        <div n:foreach="$flashes as $flash" n:class="alert, 'mb-4', ($flash->type === 'error' ? 'alert-error' : 'alert-info')">
            {$flash->message}
        </div>

        {include content}
    </main>
</body>
</html>
