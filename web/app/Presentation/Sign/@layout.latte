<!DOCTYPE html>
<html lang="cs" data-theme="light">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{ifset title}{include title|stripHtml} — {/ifset}Administrace · Survival Lodín</title>
    {asset? 'admin.js'}
</head>

<body class="min-h-screen bg-base-200">
    <main class="flex min-h-screen items-center justify-center p-4">
        <div class="w-full max-w-sm">
            <div n:foreach="$flashes as $flash" n:class="alert, 'mb-4', ($flash->type === 'error' ? 'alert-error' : 'alert-info')">
                {$flash->message}
            </div>

            {include content}
        </div>
    </main>
</body>
</html>
