services:
  - App\Core\Authenticator
  - App\Core\DomainProvider(%knownDomains%)
  - App\Model\MemberPhotoStorage(%wwwDir%/upload/teams)
  - App\Model\FileStorage(%appDir%/../data/files)
  router: App\Core\RouterFactory::createRouter()


search:
  - in: %appDir%
    classes:
      - *Facade
      - *Factory
      - *Repository
      - *Service
