root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# NEON / YAML config uses 2-space indentation in this project.
[*.{neon,yml,yaml}]
indent_size = 2

# Markdown: trailing spaces can be meaningful (hard line breaks).
[*.md]
trim_trailing_whitespace = false
